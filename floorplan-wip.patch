@@ -0,0 +1,68 @@
+import { NextResponse } from "next/server";
+import { prisma } from "@/lib/prisma";
+import { audit } from "@/lib/audit";
+import path from "path";
+import fs from "fs/promises";
+
+export async function POST(
+  _req: Request,
+  { params }: { params: Promise<{ id: string }> }
+) {
+  const { id } = await params;
+
+  const fp = await prisma.floorPlan.findUnique({ where: { id } });
+  if (!fp) return NextResponse.json({ error: "Not found" }, { status: 404 });
+
+  // Read the SVG from disk
+  const svgFile = path.join(process.cwd(), "public", fp.svgPath);
+  let svgText: string;
+  try {
+    svgText = await fs.readFile(svgFile, "utf-8");
+  } catch {
+    return NextResponse.json({ error: `SVG not found at ${fp.svgPath}` }, { status: 422 });
+  }
+
+  // Extract all data-space-id elements
+  const spaceRegex = /data-space-id="([^"]+)"[^>]*data-type="([^"]+)"/g;
+  const found = new Map<string, string>(); // externalId → blockType
+  let m: RegExpExecArray | null;
+  while ((m = spaceRegex.exec(svgText)) !== null) {
+    found.set(m[1], m[2]);
+  }
+
+  if (found.size === 0) {
+    return NextResponse.json({ error: "No data-space-id elements found in SVG" }, { status: 422 });
+  }
+
+  // Upsert Space records
+  const results = { created: 0, existing: 0 };
+  for (const [externalId, blockType] of found.entries()) {
+    const existing = await prisma.space.findUnique({ where: { externalId } });
+    if (existing) {
+      results.existing++;
+      continue;
+    }
+    // Derive a human-readable default name from the externalId
+    const name = externalId.replace(/_/g, " ").replace(/:/g, " ").replace(/\s+/g, " ").trim();
+    await prisma.space.create({
+      data: { externalId, name, blockType, floorPlanId: id },
+    });
+    results.created++;
+  }
+
+  await audit({
+    actorId: null,
+    actorType: "SYSTEM",
+    action: "create",
+    entityType: "FloorPlan.sync",
+    entityId: id,
+    after: { svgPath: fp.svgPath, created: results.created, existing: results.existing, total: found.size },
+    note: `Sync: ${results.created} new, ${results.existing} existing, ${found.size} total in SVG`,
+  });
+
+  return NextResponse.json({
+    created: results.created,
+    existing: results.existing,
+    total: found.size,
+  });
+}

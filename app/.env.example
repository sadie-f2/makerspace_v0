# Copy to .env and fill in values before running docker compose up

# PostgreSQL password for the db container
POSTGRES_PASSWORD=changeme

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=changeme

# Public URL of the app (used for OAuth redirects, email links)
AUTH_URL=https://makerspace.artisansasylum.com

# Email (smtp2go) — omit or leave blank to disable email sending
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@artisansasylum.com
SMTP_FROM_NAME=Artisans Asylum

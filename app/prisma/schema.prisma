// Makerspace management platform — Prisma schema
// Spec: /home/sadie/src/makerspace/feature-spec-okta-v0.2.1.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum MemberRole {
  MEMBER
  VOLUNTEER
  STAFF
  ADMIN
}

enum RentalRequestType {
  START
  END
}

enum RentalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WaitlistStatus {
  WAITING
  OFFERED
  ACCEPTED
  WITHDRAWN
}

enum ReservationMode {
  EXCLUSIVE
  ADVISORY
  NONE
}

enum RentalAccessScope {
  TENANT_ONLY
  TENANT_PLUS_LIST
  ORG_WIDE
}

enum ActorType {
  MEMBER
  ADMIN
  SYSTEM
}

// ---------------------------------------------------------------------------
// Identity & Auth
// ---------------------------------------------------------------------------

model Member {
  id               String      @id @default(cuid())
  email            String      @unique
  emailVerified    DateTime?
  name             String
  phone            String?
  emergencyContact String?
  passwordHash     String?     // local credentials auth; null when Okta active
  oktaId           String?     @unique
  webId            String?     // Solid/WebID — stored, not interpreted in v1.0
  stripeCustomerId  String?     @unique
  tierId            String?
  image             String?
  role                  MemberRole  @default(MEMBER)
  requiresPasswordReset Boolean     @default(false)
  accessSuspended       Boolean     @default(false)
  accessSuspendedAt DateTime?
  deletedAt         DateTime?
  deletedById      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tier             MemberTier?        @relation(fields: [tierId], references: [id])
  accounts         Account[]
  sessions         Session[]
  certifications   Certification[]
  reservations     Reservation[]
  rentals          Rental[]
  dayPasses        DayPass[]
  auditLogs        AuditLog[]         @relation("AuditActor")
  permissions      MemberPermission[] @relation("PermissionHolder")
  permissionsGranted MemberPermission[] @relation("PermissionGrantor")
  rentalRequests   RentalRequest[]    @relation("RentalRequester")
  rentalRequestsReviewed RentalRequest[] @relation("RentalRequestReviewer")
  waitlistEntries  WaitlistEntry[]
}

model MemberTier {
  id             String    @id @default(cuid())
  name           String    @unique
  slug           String    @unique
  monthlyRate    Decimal   @db.Decimal(10, 2)
  canBook        Boolean   @default(true)
  canRentStudio  Boolean   @default(false)
  canRentStorage Boolean   @default(true)
  buildingAccess Boolean   @default(true)
  active         Boolean   @default(true)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members        Member[]
}

// NextAuth v5 required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Member @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user Member @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Equipment & Certifications
// ---------------------------------------------------------------------------

model EquipmentClass {
  id             String          @id @default(cuid())
  name           String          @unique
  description    String?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  certifications Certification[]
  resources      Resource[]
}

model Certification {
  id               String   @id @default(cuid())
  memberId         String
  equipmentClassId String
  grantedAt        DateTime @default(now())
  grantedById      String
  revokedAt        DateTime?
  revokedById      String?

  member         Member         @relation(fields: [memberId], references: [id])
  equipmentClass EquipmentClass @relation(fields: [equipmentClassId], references: [id])

  @@unique([memberId, equipmentClassId])
}

// ---------------------------------------------------------------------------
// Resource tree (unified model for tools, rooms, studios, storage, etc.)
// ---------------------------------------------------------------------------

model Resource {
  id                  String           @id @default(cuid())
  name                String
  description         String?
  typeTag             String           // descriptive only — never used to branch logic
  parentId            String?
  reservable          Boolean          @default(false)
  leasable            Boolean          @default(false)
  reservationMode     ReservationMode  @default(NONE)
  rentalAccessScope   RentalAccessScope @default(ORG_WIDE)
  requiresCertClassId String?
  outOfService        Boolean          @default(false)
  outOfServiceAt      DateTime?
  outOfServiceNote    String?
  deletedAt           DateTime?
  deletedById         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  parent            Resource?       @relation("ResourceTree", fields: [parentId], references: [id])
  children          Resource[]      @relation("ResourceTree")
  requiresCertClass EquipmentClass? @relation(fields: [requiresCertClassId], references: [id])
  spaces            Space[]
  reservations      Reservation[]
  rentals           Rental[]
  rentalRequests    RentalRequest[]
  waitlistOffers    WaitlistEntry[]
}

// ---------------------------------------------------------------------------
// Reservations (time-bounded bookings)
// ---------------------------------------------------------------------------

model Reservation {
  id          String    @id @default(cuid())
  resourceId  String
  memberId    String
  startAt     DateTime
  endAt       DateTime
  notes       String?
  deletedAt   DateTime? // soft cancel
  deletedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id])
  member   Member   @relation(fields: [memberId], references: [id])
}

// ---------------------------------------------------------------------------
// Rentals (studio/storage long-term assignments)
// ---------------------------------------------------------------------------

model Rental {
  id                       String    @id @default(cuid())
  resourceId               String
  memberId                 String
  startDate                DateTime
  endDate                  DateTime? // null = ongoing
  monthlyRate              Decimal   @db.Decimal(10, 2)
  stripeSubscriptionId     String?   @unique // Stripe Subscription ID
  stripeSubscriptionItemId String?           // Stripe SubscriptionItem ID
  stripeSubscriptionStatus String?           // active | past_due | canceled | etc.
  deletedAt                DateTime?
  deletedById              String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  resource       Resource        @relation(fields: [resourceId], references: [id])
  member         Member          @relation(fields: [memberId], references: [id])
  rentalRequests RentalRequest[]
}

// ---------------------------------------------------------------------------
// Member fine-grained permissions
// ---------------------------------------------------------------------------

model MemberPermission {
  id          String    @id @default(cuid())
  memberId    String
  permission  String    // e.g. "role.shop_lead", "equipment.mark_down", "certifications.grant.<classId>"
  grantedById String
  grantedAt   DateTime  @default(now())
  expiresAt   DateTime?

  member    Member @relation("PermissionHolder", fields: [memberId], references: [id])
  grantedBy Member @relation("PermissionGrantor", fields: [grantedById], references: [id])

  @@unique([memberId, permission])
}

// ---------------------------------------------------------------------------
// Rental requests (member-initiated; staff/admin approves)
// ---------------------------------------------------------------------------

model RentalRequest {
  id                   String              @id @default(cuid())
  memberId             String
  resourceId           String
  requestType          RentalRequestType
  requestedStartDate   DateTime?           // for START requests
  requestedMonthlyRate Decimal?            @db.Decimal(10, 2)
  rentalId             String?             // linked on END approval
  status               RentalRequestStatus @default(PENDING)
  reviewedById         String?
  reviewedAt           DateTime?
  reviewNote           String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  member     Member   @relation("RentalRequester", fields: [memberId], references: [id])
  resource   Resource @relation(fields: [resourceId], references: [id])
  reviewedBy Member?  @relation("RentalRequestReviewer", fields: [reviewedById], references: [id])
  rental     Rental?  @relation(fields: [rentalId], references: [id])
}

// ---------------------------------------------------------------------------
// Waitlist (studio / storage queue)
// ---------------------------------------------------------------------------

model WaitlistEntry {
  id                String         @id @default(cuid())
  memberId          String
  resourceTypeTag   String         // "studio" | "storage_unit" | etc.
  requestedAt       DateTime       @default(now())
  status            WaitlistStatus @default(WAITING)
  note              String?
  offeredResourceId String?
  offeredAt         DateTime?

  member          Member    @relation(fields: [memberId], references: [id])
  offeredResource Resource? @relation(fields: [offeredResourceId], references: [id])
}

// ---------------------------------------------------------------------------
// Day passes (physical fob model — no Okta/Brivo provisioning)
// ---------------------------------------------------------------------------

model DayPass {
  id                    String    @id @default(cuid())
  memberId              String?   // null for walk-in purchases
  purchasedAt           DateTime  @default(now())
  validDate             DateTime
  fobNumber             String?
  stripePaymentIntentId String?
  returnedAt            DateTime?
  notes                 String?
  createdAt             DateTime  @default(now())

  member Member? @relation(fields: [memberId], references: [id])
}

// ---------------------------------------------------------------------------
// Space type configuration (org-configurable; slug is the stable internal key)
// ---------------------------------------------------------------------------

model SpaceTypeConfig {
  id                   String   @id @default(cuid())
  slug                 String   @unique // permanent internal key — never change once spaces are assigned
  label                String           // display name; freely editable (e.g. "Shop" → "Lab")
  parentId             String?          // non-null for subtypes (e.g. storage variants)
  dxfLayer             String?          // DXF layer name (or base prefix for multilevel); null = not on floor plan
  dxfBlockPattern      String?          // DXF block name prefix for INSERT matching (e.g. "sb-std" matches "sb-std-l", "sb-std-p")
  dxfLabelLayer        String?          // DXF layer holding TEXT labels/codes for this type (e.g. "studio_label", "storage_label")
  dxfProcessingMode    String?          // "insert_numbered" | "insert_coded" | "insert_multilevel" | "polyline_labeled"
  color                String?          // hex fill for floor plan viewer; null = inherit from parent or theme default
  isBookable           Boolean  @default(false)
  isLeasable           Boolean  @default(false)
  active               Boolean  @default(true)
  sortOrder            Int      @default(0)
  defaultMonthlyRate   Decimal? @db.Decimal(10, 2) // suggested rate when creating a rental of this type
  membershipRequirement String?          // null = any member; "7x24" = full member required; extensible
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  parent   SpaceTypeConfig?  @relation("SpaceTypeTree", fields: [parentId], references: [id])
  children SpaceTypeConfig[] @relation("SpaceTypeTree")
}

// ---------------------------------------------------------------------------
// Studio assembly sizes (allowed unit counts — configurable by admin)
// ---------------------------------------------------------------------------

model StudioSize {
  id        String   @id @default(cuid())
  unitCount Int      @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Floor plans & spaces
// ---------------------------------------------------------------------------

model FloorPlan {
  id        String   @id @default(cuid())
  building  String
  floor     Int
  svgPath   String   // always the current approved SVG path (denormalized from latest revision)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  spaces    Space[]
  revisions FloorPlanRevision[]

  @@unique([building, floor])
}

model FloorPlanRevision {
  id           String   @id @default(cuid())
  floorPlanId  String
  svgPath      String
  dxfData      Bytes?   // DXF file bytes — DB is authoritative source for re-export
  note         String?
  uploadedAt   DateTime @default(now())
  uploadedById String?  // Member id; null = system/CLI upload

  floorPlan    FloorPlan @relation(fields: [floorPlanId], references: [id])
}

model Space {
  id          String   @id @default(cuid())
  externalId  String   @unique // matches data-space-id in SVG; permanent join key
  name        String
  blockType   String
  floorPlanId String
  resourceId  String?          // nullable for common areas; multiple units can share one Resource (studio grouping)
  bayCode     String?          // storage shelf bays only — e.g. "A1"; groups levels of the same physical bay
  shelfLevel  Int?             // storage shelf bays only — 1 = lowest physical level
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floorPlan FloorPlan @relation(fields: [floorPlanId], references: [id])
  resource  Resource? @relation(fields: [resourceId], references: [id])
}

// ---------------------------------------------------------------------------
// Audit log (append-only — application code never updates or deletes rows)
// ---------------------------------------------------------------------------

model AuditLog {
  id         String    @id @default(cuid())
  timestamp  DateTime  @default(now())
  actorId    String?   // null = system or webhook
  actorType  ActorType @default(MEMBER)
  action     String    // "create" | "update" | "delete" | "restore" | "undo"
  entityType String
  entityId   String
  before     Json?
  after      Json?
  note       String?   // written at mutation time; immutable after creation
  flagNote   String?   // post-hoc annotation: error flag or correction note
  undoOfId   String?   // set on action="undo" entries; points to original entry
  ipAddress  String?

  actor   Member?   @relation("AuditActor", fields: [actorId], references: [id])
  undoOf  AuditLog? @relation("UndoChain", fields: [undoOfId], references: [id])
  undone  AuditLog[] @relation("UndoChain")
}

// ---------------------------------------------------------------------------
// System configuration (single row; systemFreeze halts all writes)
// ---------------------------------------------------------------------------

model SystemConfig {
  id           String   @id @default(cuid())
  systemFreeze Boolean  @default(false)
  timezone     String   @default("America/New_York") // IANA timezone string
  updatedById  String?
  updatedAt    DateTime @updatedAt
}
